<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
  </head>
  <body>
    <div class="container">
      <h1 class="mt-4">URL Shortner</h1>

      <form class="form-group" action="/post-url" method="post">
        <label class="sr-only sr-only-focusable" for="full-url">Url</label>
        <input
          class="form-control"
          required
          placeholder="Url"
          type="url"
          name="full-url"
          id="full-url"
        />
        <button class="mt-1 btn btn-success" type="submit">Shrink</button>
      </form>

      <table class="table">
        <thead>
          <tr>
            <th>Full URL</th>
            <th>Short URL</th>
            <th>Clicks</th>
          </tr>
        </thead>
        <tbody>
          <% shortUrls.forEach(function (shortUrl) { %>
          <tr>
            <td>
              <a href="<%= shortUrl.full_url %>"><%= shortUrl.full_url %></a>
            </td>
            <td>
              <a href="<%= shortUrl.short_url%>"><%=shortUrl.short_url %></a>
            </td>
            <td><%=shortUrl.clicks%></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </body>
</html>
